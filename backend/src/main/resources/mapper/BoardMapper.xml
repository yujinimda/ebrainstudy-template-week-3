<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- namespace = 이 XML이 구현하는 매퍼 인터페이스의 전체 경로 -->
<mapper namespace="com.ebsoft.board.board.mapper.BoardMapper">

    <!--
      검색 WHERE 조각. findBoards / countBoards가 <include>로 공유한다.
      <where> : 안에 조건이 하나도 없으면 WHERE 자체를 안 붙이고,
                있으면 맨 앞의 AND를 자동으로 떼 준다.
    -->
    <sql id="searchWhere">
        <where>
            <!-- 검색어: 제목 또는 내용에 keyword 포함 (예시 — 이걸 참고하세요) -->
            <if test="keyword != null and keyword != ''">
                AND (title LIKE CONCAT('%', #{keyword}, '%')
                  OR content LIKE CONCAT('%', #{keyword}, '%'))
            </if>

            <!-- 카테고리 필터: categoryId가 있을 때만 -->
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>

        </where>
    </sql>

    <!-- 이번 페이지 목록: 최신순, size개씩, offset만큼 건너뛰고 -->
    <select id="findBoards"
            parameterType="com.ebsoft.board.board.dto.BoardSearchRequest"
            resultType="com.ebsoft.board.board.domain.Board">
        SELECT board_id, category_id, title, content, writer, view_count, created_at, updated_at
        FROM board
        <include refid="searchWhere"/>
        ORDER BY board_id DESC
        LIMIT #{size} OFFSET #{offset}
    </select>

    <!-- 조건에 맞는 전체 개수 (같은 searchWhere 재사용 -> 목록과 count가 항상 일치) -->
    <select id="countBoards"
            parameterType="com.ebsoft.board.board.dto.BoardSearchRequest"
            resultType="long">
        SELECT COUNT(*)
        FROM board
        <include refid="searchWhere"/>
    </select>

    <!-- 게시글 1건 조회 (예시 — 이걸 참고하세요) -->
    <select id="findById" resultType="com.ebsoft.board.board.domain.Board">
        SELECT board_id, category_id, title, content, writer, view_count, created_at, updated_at
        FROM board
        WHERE board_id = #{boardId}
    </select>

    <!-- TODO(human): 조회수 +1 UPDATE 쿼리를 작성하세요.
         목표 : board_id 가 #{boardId} 인 글의 view_count 를 1 올린다
         구조 : <update id="increaseViewCount"> ... </update>  (위 <select> 흉내내되 UPDATE)
         SQL  : UPDATE board SET view_count = <????> WHERE board_id = #{boardId}
         힌트 : "현재 값 + 1" 을 DB에서 직접 계산 -> view_count = view_count + 1
                (앱에서 읽어와 더하지 않는다. 그래야 동시에 여러 명이 봐도 안 샌다.)
    -->
    <update id="increaseViewCount">
        UPDATE board
        SET view_count = view_count + 1
        WHERE board_id = #{boardId}
    </update>

    <!-- TODO(human): 게시글 INSERT 쿼리를 작성하세요.
         목표 : board 테이블에 새 글 한 줄 추가하고, 생성된 board_id 를 되돌려받기

         뼈대(이미 열어둠) :
             <insert id="insertBoard"
                     parameterType="com.ebsoft.board.board.domain.Board"
                     useGeneratedKeys="true" keyProperty="boardId">
                 INSERT INTO board (....) VALUES (....)
             </insert>

         넣을 컬럼 : category_id, title, content, writer, password
             → 값은 #{categoryId}, #{title}, #{content}, #{writer}, #{password}
                (Board 객체의 필드명을 그대로 #{} 안에 쓴다)

         빼는 컬럼(=DB가 알아서 채움, 스키마 DEFAULT 참고) :
             board_id   → AUTO_INCREMENT
             view_count → DEFAULT 0
             created_at → DEFAULT CURRENT_TIMESTAMP
             updated_at → 수정 전이라 NULL

         useGeneratedKeys/keyProperty 의 의미 :
             INSERT 후 MySQL이 만든 새 board_id 를 넘겨준 Board 객체의 boardId 에 자동 세팅.
             → Service에서 insert 직후 board.getBoardId() 로 새 글 번호를 알 수 있다.
    -->
    <insert id="insertBoard"
        parameterType="com.ebsoft.board.board.domain.Board"
        useGeneratedKeys="true"  keyProperty="boardId">
        INSERT INTO board (category_id, title, content, writer, password)
        VALUES (#{categoryId}, #{title}, #{content}, #{writer}, #{password})
    </insert>





</mapper>
